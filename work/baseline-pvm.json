  // ============================================================
  // 11. iptables filter 规则（FORWARD 链）
  // ============================================================
  "iptables_filter": {
    "default_policies": {
      "INPUT":   {"current":"ACCEPT", "expected":"ACCEPT", "severity_if_changed":"INFO"},
      "FORWARD": {"current":"ACCEPT", "expected":"ACCEPT",
                  "severity_if_changed":"WARN",
                  "_note":"FORWARD 默认 ACCEPT 是已知安全 WARN，依赖 DNAT 隐式过滤"},
      "OUTPUT":  {"current":"ACCEPT", "expected":"ACCEPT", "severity_if_changed":"INFO"}
    },
    "forward_rules": [
      {"rule_id":"FWD_VLAN3_OUT",
       "must_contain":"-A FORWARD -i vmtap1.3 -o eth1.3 -j ACCEPT",
       "in":"vmtap1.3", "out":"eth1.3", "target":"ACCEPT"},
      {"rule_id":"FWD_VLAN3_IN_STATEFUL",
       "must_contain":"-A FORWARD -i eth1.3 -o vmtap1.3 -m state --state RELATED,ESTABLISHED -j ACCEPT",
       "in":"eth1.3", "out":"vmtap1.3", "state":"RELATED,ESTABLISHED", "target":"ACCEPT"},
      {"rule_id":"FWD_VLAN4_OUT",
       "must_contain":"-A FORWARD -i vmtap1.4 -o eth1.4 -j ACCEPT",
       "in":"vmtap1.4", "out":"eth1.4", "target":"ACCEPT"},
      {"rule_id":"FWD_VLAN4_IN_STATEFUL",
       "must_contain":"-A FORWARD -i eth1.4 -o vmtap1.4 -m state --state RELATED,ESTABLISHED -j ACCEPT",
       "in":"eth1.4", "out":"vmtap1.4", "state":"RELATED,ESTABLISHED", "target":"ACCEPT"},
      {"rule_id":"FWD_VLAN6_OUT",
       "must_contain":"-A FORWARD -i vmtap1.6 -o eth1.6 -j ACCEPT",
       "in":"vmtap1.6", "out":"eth1.6", "target":"ACCEPT"},
      {"rule_id":"FWD_VLAN6_IN_STATEFUL",
       "must_contain":"-A FORWARD -i eth1.6 -o vmtap1.6 -m state --state RELATED,ESTABLISHED -j ACCEPT",
       "in":"eth1.6", "out":"vmtap1.6", "state":"RELATED,ESTABLISHED", "target":"ACCEPT"},
      {"rule_id":"FWD_VLAN7_OUT",
       "must_contain":"-A FORWARD -i vmtap1.7 -o eth1.7 -j ACCEPT",
       "in":"vmtap1.7", "out":"eth1.7", "target":"ACCEPT"},
      {"rule_id":"FWD_VLAN7_IN_STATEFUL",
       "must_contain":"-A FORWARD -i eth1.7 -o vmtap1.7 -m state --state RELATED,ESTABLISHED -j ACCEPT",
       "in":"eth1.7", "out":"vmtap1.7", "state":"RELATED,ESTABLISHED", "target":"ACCEPT"},
      {"rule_id":"FWD_VLAN8_OUT",
       "must_contain":"-A FORWARD -i vmtap1.8 -o eth1.8 -j ACCEPT",
