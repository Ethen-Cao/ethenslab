  // ============================================================
  // 15. 差异策略（diff_policy）
  // ============================================================
  "diff_policy": {
    "ignore_fields": [
      "iptables_counters",
      "carrier_changes_total",
      "conntrack_count",
      "neigh_state_transient_states"
    ],
    "info_if_changed": [
      "documented_bind_any_observed"
    ],
    "warn_if_changed": [
      "iptables_filter.default_policies",
      "kernel_params.net.ipv4.ip_forward",
      "kernel_params.net.ipv4.conf.all.rp_filter"
    ],
    "fail_if_changed": [
      "phys_ifaces[*].expected_mac",
      "vlan_ifaces[*].ip",
      "vmtap[*].ip",
      "main_table.default",
      "policy_route",
      "iptables_nat.prerouting",
      "iptables_nat.postrouting",
      "per_iface_params[*].forwarding",
      "per_iface_params[*].rp_filter",
      "pvm_only_vlans",
      "gateways[*].ip"
    ],
    "fail_if_missing": [
      "phys_ifaces",
      "vlan_ifaces",
      "vmtap",
      "iptables_nat.prerouting.VLAN3_DNAT",
      "iptables_nat.prerouting.VLAN4_IDPS_EXCEPT_DNAT_TCP",
      "iptables_nat.prerouting.VLAN4_IDPS_EXCEPT_DNAT_NONTCP"
    ]
  }
