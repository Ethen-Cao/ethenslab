  // ============================================================
  // 10. iptables NAT 规则（PREROUTING + POSTROUTING）
  //    格式：把每条规则结构化，方便 NetfilterCollector 抽象层比对
  // ============================================================
  "iptables_nat": {
    "prerouting": [
      {
        "rule_id":     "VLAN3_DNAT",
        "must_contain":"-A PREROUTING -d 172.16.103.40/32 -i eth1.3 -j DNAT --to-destination 10.10.103.40",
        "in_iface":    "eth1.3",
        "dst_ip":      "172.16.103.40/32",
        "target":      "DNAT",
        "to":          "10.10.103.40"
      },
      {
        "rule_id":     "VLAN4_IDPS_EXCEPT_DNAT_TCP",
        "must_contain":"-A PREROUTING -d 172.16.104.40/32 -i eth1.4 -p tcp -m tcp ! --dport 30006 -j DNAT --to-destination 10.10.104.40",
        "in_iface":    "eth1.4",
        "dst_ip":      "172.16.104.40/32",
        "proto":       "tcp",
        "dport_not":   30006,
        "target":      "DNAT",
        "to":          "10.10.104.40",
        "order_constraint":{"before":"VLAN4_IDPS_EXCEPT_DNAT_NONTCP",
                            "_note":"IDPS 旁路必须先排除 TCP/30006"}
      },
      {
        "rule_id":     "VLAN4_IDPS_EXCEPT_DNAT_NONTCP",
        "must_contain":"-A PREROUTING -d 172.16.104.40/32 -i eth1.4 ! -p tcp -j DNAT --to-destination 10.10.104.40",
        "in_iface":    "eth1.4",
        "dst_ip":      "172.16.104.40/32",
        "proto_not":   "tcp",
        "target":      "DNAT",
        "to":          "10.10.104.40"
      },
      {
        "rule_id":     "VLAN6_DNAT",
        "must_contain":"-A PREROUTING -d 172.16.106.40/32 -i eth1.6 -j DNAT --to-destination 10.10.106.40",
        "in_iface":    "eth1.6",
        "dst_ip":      "172.16.106.40/32",
        "target":      "DNAT",
        "to":          "10.10.106.40"
      },
      {
        "rule_id":     "VLAN7_DNAT",
        "must_contain":"-A PREROUTING -d 172.16.107.40/32 -i eth1.7 -j DNAT --to-destination 10.10.107.40",
        "in_iface":    "eth1.7",
        "dst_ip":      "172.16.107.40/32",
        "target":      "DNAT",
        "to":          "10.10.107.40"
      },
      {
        "rule_id":     "VLAN8_DNAT",
        "must_contain":"-A PREROUTING -d 172.16.108.40/32 -i eth1.8 -j DNAT --to-destination 10.10.108.40",
        "in_iface":    "eth1.8",
        "dst_ip":      "172.16.108.40/32",
        "target":      "DNAT",
        "to":          "10.10.108.40"
      }
    ],
    "postrouting": [
      {
        "rule_id":     "VLAN3_RETURN_SNAT",
        "must_contain":"-A POSTROUTING -d 10.10.103.40/32 -o vmtap1.3 -j SNAT --to-source 10.10.103.1",
        "dst_ip":      "10.10.103.40/32", "out_iface":"vmtap1.3", "target":"SNAT", "to":"10.10.103.1"
      },
      {
        "rule_id":     "VLAN3_OUT_SNAT",
        "must_contain":"-A POSTROUTING -s 10.10.103.0/24 -o eth1.3 -j SNAT --to-source 172.16.103.40",
        "src_ip":      "10.10.103.0/24", "out_iface":"eth1.3", "target":"SNAT", "to":"172.16.103.40"
      },
      {
        "rule_id":     "VLAN4_RETURN_SNAT",
        "must_contain":"-A POSTROUTING -d 10.10.104.40/32 -o vmtap1.4 -j SNAT --to-source 10.10.104.1",
        "dst_ip":      "10.10.104.40/32", "out_iface":"vmtap1.4", "target":"SNAT", "to":"10.10.104.1"
      },
      {
        "rule_id":     "VLAN4_OUT_SNAT",
        "must_contain":"-A POSTROUTING -s 10.10.104.0/24 -o eth1.4 -j SNAT --to-source 172.16.104.40",
        "src_ip":      "10.10.104.0/24", "out_iface":"eth1.4", "target":"SNAT", "to":"172.16.104.40"
      },
      {
        "rule_id":     "VLAN6_RETURN_SNAT",
        "must_contain":"-A POSTROUTING -d 10.10.106.40/32 -o vmtap1.6 -j SNAT --to-source 10.10.106.1",
        "dst_ip":      "10.10.106.40/32", "out_iface":"vmtap1.6", "target":"SNAT", "to":"10.10.106.1"
      },
      {
        "rule_id":     "VLAN6_OUT_SNAT",
        "must_contain":"-A POSTROUTING -s 10.10.106.0/24 -o eth1.6 -j SNAT --to-source 172.16.106.40",
        "src_ip":      "10.10.106.0/24", "out_iface":"eth1.6", "target":"SNAT", "to":"172.16.106.40"
      },
      {
        "rule_id":     "VLAN7_RETURN_SNAT",
        "must_contain":"-A POSTROUTING -d 10.10.107.40/32 -o vmtap1.7 -j SNAT --to-source 10.10.107.1",
        "dst_ip":      "10.10.107.40/32", "out_iface":"vmtap1.7", "target":"SNAT", "to":"10.10.107.1"
