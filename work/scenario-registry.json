        ],
        "decision_logic": [
          "1. PVM ping -I eth1.3 8.8.8.8 不通 → TBOX 上游问题 (非座舱故障)",
          "2. PVM 通但 GVM 不通 → forwarding / SNAT / conntrack / virtio",
          "3. GVM ping 公网 IP 通但 DNS 失败 → 进入场景 J",
          "4. GVM 到 10.10.103.1 不通 → vmtap / virtio"
        ]
      },

      "probes": [
        "SHU_VLAN3_INTERNET.icmp_tbox",
        "SHU_VLAN3_INTERNET.icmp_uplink",
        "SHU_VLAN3_INTERNET.icmp_gvm_perspective"
      ],

      "evidence_packs": [
        "pvm/sysctl_net.txt (forwarding/rp_filter)",
        "pvm/iptables_nat_Lnv.txt (counters)",
        "pvm/conntrack_count_max.txt",
        "pvm/conntrack_state_breakdown.txt",
        "pvm/nat_symmetry_history.jsonl",
        "gvm/ip_route_all.txt"
      ],

      "expected_fault_classes_on_failure": [
        "FORWARDING_DISABLED", "DOWNSTREAM_PACKET_LOSS",
        "NAT_RULE_DRIFT", "VM_LINK_BROKEN", "TBOX_UPLINK_DOWN"
      ],

      "test_cases":       ["TC-NET-022", "TC-NET-023", "TC-NET-024"]
    }
  ],

  // ============================================================
  // VLAN 维度的诊断 scope（MODE-002 按 VLAN 专项）
  // 把上面的 scenarios 反向映射到 VLAN，便于"按 VLAN 跑诊断"
  // ============================================================
  "vlan_scope_filter": {
    "VLAN_3":  {"scenarios":["A_GVM_INTERNET_DOWN","J_DNS_FAILURE","L_PVM_OK_GVM_NO_INTERNET"],
                "extra_checks":["SVC-012"]},
    "VLAN_4":  {"scenarios":["B_DIAG_DOIP_UNREACHABLE","C_IDPS_BYPASS_FAIL"]},
    "VLAN_6":  {"scenarios":["D_ADCU_PARK_UNREACHABLE"]},
    "VLAN_7":  {"scenarios":["E_OTA_CHANNEL_FAIL"]},
    "VLAN_8":  {"scenarios":["F_ADAS_INTERNET_FAIL"]},
    "VLAN_10": {"scenarios":["G_SOMEIP_SERVICE_FAIL"], "pvm_only":true},
    "VLAN_11": {"scenarios":["G_SOMEIP_SERVICE_FAIL"], "pvm_only":true},
    "VLAN_12": {"scenarios":["G_SOMEIP_SERVICE_FAIL"], "pvm_only":true},
    "VLAN_13": {"scenarios":["G_SOMEIP_SERVICE_FAIL"], "pvm_only":true},
    "VLAN_14": {"scenarios":["G_SOMEIP_SERVICE_FAIL"], "pvm_only":true},
    "VLAN_15": {"scenarios":["H_CAMERA_NO_VIDEO"], "pvm_only":true,
                "out_of_scope_hint":"mmhab 后段超出范围"},
    "VLAN_19": {"scenarios":["G_SOMEIP_SERVICE_FAIL"], "pvm_only":true,
                "_note":"ADCU 大数据 SOME/IP"},
    "HOST_GUEST": {"scenarios":["I_HOST_GUEST_BROKEN"]}
  },

  // ============================================================
  // 故障触发模式 (MODE-004) — watchdog 信号到 scenario 的映射
  // ============================================================
  "watchdog_trigger_to_scenarios": {
    "WD_PVM_LINK(eth1)":            ["A_GVM_INTERNET_DOWN","B_DIAG_DOIP_UNREACHABLE",
                                     "D_ADCU_PARK_UNREACHABLE","E_OTA_CHANNEL_FAIL",
                                     "F_ADAS_INTERNET_FAIL","G_SOMEIP_SERVICE_FAIL"],
    "WD_PVM_LINK(eth0)":            ["H_CAMERA_NO_VIDEO","G_SOMEIP_SERVICE_FAIL"],
    "WD_PVM_VMTAP_OPER":            ["I_HOST_GUEST_BROKEN"],
    "WD_PVM_FORWARDING":            ["L_PVM_OK_GVM_NO_INTERNET","A_GVM_INTERNET_DOWN"],
    "WD_PVM_CONNTRACK_PCT":         ["K_CONNTRACK_FULL","A_GVM_INTERNET_DOWN"],
    "WD_PVM_CONNTRACK_FULL":        ["K_CONNTRACK_FULL"],
    "WD_PVM_CONNTRACK_UNREPLIED":   ["L_PVM_OK_GVM_NO_INTERNET","K_CONNTRACK_FULL"],
    "WD_PVM_NAT_RULES":             ["B_DIAG_DOIP_UNREACHABLE","C_IDPS_BYPASS_FAIL","A_GVM_INTERNET_DOWN"],
    "WD_PVM_NAT_ASYMMETRY":         ["L_PVM_OK_GVM_NO_INTERNET","A_GVM_INTERNET_DOWN"],
    "WD_PVM_HYPERVISOR":            ["I_HOST_GUEST_BROKEN"],
    "WD_PVM_SERVICE(xdja_idps)":    ["C_IDPS_BYPASS_FAIL"],
    "WD_PVM_SERVICE(someipd_*)":    ["G_SOMEIP_SERVICE_FAIL"],
    "WD_PVM_SERVICE(camera_server)":["H_CAMERA_NO_VIDEO"],
    "WD_GVM_NETD":                  ["J_DNS_FAILURE","A_GVM_INTERNET_DOWN"],
    "WD_GVM_CONNECTIVITY":          ["A_GVM_INTERNET_DOWN"]
  },

  // ============================================================
  // 实现注意事项
  // ============================================================
  "implementation_notes": [
    "scenarios.checks.must_run 列出 MODE-003 时必跑的 check_id",
    "scenarios.probes 引用 SHU.probes 的具体 probe_id",
    "scenarios.evidence_packs 列出 incident_dir 需保留的关键证据文件路径",
    "vlan_scope_filter 支持 MODE-002 (按 VLAN 专项)：scope=VLAN_3 → 跑这些 scenarios 的 must_run 检查",
    "watchdog_trigger_to_scenarios 支持 MODE-004：watchdog 信号触发后自动跑对应 scenarios.checks.must_run",
    "passive_only=true 表示需外部流量配合（如诊断仪），不能内部主动构造；若无流量到达，scene 检查输出 BLOCKED-L1_env"
  ]
}
